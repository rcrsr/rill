{
  "name": "feedback-analyzer",
  "version": "0.1.0",
  "runtime": "@rcrsr/rill@*",
  "entry": "scripts/main.rill",
  "description": "Analyze customer feedback with structured output and response drafting",
  "extensions": {
    "llm": {
      "package": "@rcrsr/rill-ext-openai",
      "config": {
        "api_key": "${GROQ_API_KEY}",
        "model": "meta-llama/llama-4-scout-17b-16e-instruct",
        "base_url": "https://api.groq.com/openai/v1"
      }
    }
  },
  "host": {
    "timeout": 30000
  },
  "deploy": {
    "port": 4001
  }
}
