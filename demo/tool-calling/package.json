{
  "name": "rill-demo-tool-calling",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rill-agent-bundle build agent.json",
    "check": "rill-agent-bundle check --platform node dist/",
    "start": "rill-agent-run dist/ tool-calling --config config.json --param question='What is the weather in Paris and Tokyo? Convert the Paris temperature to Fahrenheit.'"
  },
  "dependencies": {
    "@rcrsr/rill": "workspace:*",
    "@rcrsr/rill-agent-harness": "workspace:*",
    "@rcrsr/rill-ext-openai": "workspace:*",
    "@rcrsr/rill-agent-bundle": "workspace:*",
    "@rcrsr/rill-agent-run": "workspace:*"
  }
}
