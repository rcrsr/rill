{
  "name": "rill-lang",
  "version": "0.19.4",
  "description": "Scripting designed for machine-generated code",
  "private": true,
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcrsr/rill.git"
  },
  "bugs": {
    "url": "https://github.com/rcrsr/rill/issues"
  },
  "homepage": "https://github.com/rcrsr/rill#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "lefthook install --force",
    "build": "pnpm -r run build",
    "build:dev": "pnpm -r --if-present run build:dev",
    "test": "pnpm -r run test",
    "test:watch": "vitest",
    "test:examples": "pnpm --filter @rcrsr/rill run test:examples",
    "check": "pnpm -r run check",
    "check:types": "pnpm -r run typecheck",
    "check:lint": "pnpm -r run lint",
    "check:format": "oxfmt --check",
    "check:deps": "knip",
    "check:versions": "bash scripts/check-versions.sh",
    "fix:lint": "oxlint --fix",
    "fix:format": "oxfmt",
    "fix:versions": "bash scripts/sync-versions.sh"
  },
  "keywords": [
    "rill",
    "scripting",
    "dsl",
    "pipe",
    "workflow",
    "parser",
    "interpreter"
  ],
  "author": "Andre Bremer",
  "license": "MIT",
  "engines": {
    "node": ">=22.16.0"
  },
  "devDependencies": {
    "@rcrsr/rill": "workspace:*",
    "@types/node": "^26.1.1",
    "knip": "^6.25.0",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10",
    "yaml": "^2.9.0"
  }
}
