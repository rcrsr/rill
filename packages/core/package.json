{
  "name": "@rcrsr/rill",
  "version": "0.19.0",
  "description": "Scripting designed for machine-generated code",
  "license": "MIT",
  "author": "Andre Bremer",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "keywords": [
    "rill",
    "scripting",
    "parser",
    "runtime",
    "pipes",
    "machine-generated"
  ],
  "files": [
    "dist",
    "docs"
  ],
  "scripts": {
    "build": "tsx scripts/generate-version.ts && tsx scripts/generate-docs-bundle.ts && tsc --build",
    "build:dev": "tsx scripts/generate-version.ts && tsx scripts/generate-docs-bundle.ts && tsc --build tsconfig.dev.json",
    "pretest": "tsx scripts/generate-version.ts",
    "test": "vitest run",
    "test:examples": "tsx ../../scripts/test-examples.ts ../../docs/",
    "typecheck": "tsc --noEmit",
    "lint": "eslint --config ../../eslint.config.js src/",
    "lint:self-test": "node ../../eslint-rules/lint-glob-self-test.cjs",
    "docs:errors": "tsx scripts/generate-error-docs.ts",
    "check": "pnpm run build && pnpm run test && pnpm run test:examples && pnpm run lint:self-test && pnpm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rcrsr/rill.git",
    "directory": "packages/core"
  },
  "homepage": "https://rill.run",
  "bugs": {
    "url": "https://github.com/rcrsr/rill/issues"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
